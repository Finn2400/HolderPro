{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/dist/${presetName}",
        "CMAKE_PREFIX_PATH": "$env{HOLDERPRO_PRUSASLICER_DEPS_PREFIX}",
        "HOLDERPRO_ENABLE_DEAD_CODE_ELIMINATION": "ON",
        "HOLDERPRO_ENABLE_LTO": "ON",
        "HOLDERPRO_RUNTIME_DEPENDENCY_DIR": "$env{HOLDERPRO_PRUSASLICER_DEPS_BIN}",
        "PRUSASLICER_SOURCE_DIR": "$env{PRUSASLICER_SOURCE_DIR}",
        "SLIC3R_STATIC": "ON"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 release",
      "inherits": "release-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0"
      }
    },
    {
      "name": "macos-x86_64",
      "displayName": "macOS Intel release",
      "inherits": "release-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "architecture": {
        "value": "x86_64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0"
      }
    },
    {
      "name": "linux-x86_64",
      "displayName": "Linux x86_64 release",
      "inherits": "release-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "architecture": {
        "value": "x86_64",
        "strategy": "external"
      }
    },
    {
      "name": "windows-x86_64",
      "displayName": "Windows x86_64 release",
      "inherits": "release-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    }
  ],
  "buildPresets": [
    { "name": "macos-arm64", "configurePreset": "macos-arm64", "targets": ["holderpro-organic-engine", "holderpro-private-output-test"] },
    { "name": "macos-x86_64", "configurePreset": "macos-x86_64", "targets": ["holderpro-organic-engine", "holderpro-private-output-test"] },
    { "name": "linux-x86_64", "configurePreset": "linux-x86_64", "targets": ["holderpro-organic-engine", "holderpro-private-output-test"] },
    { "name": "windows-x86_64", "configurePreset": "windows-x86_64", "targets": ["holderpro-organic-engine", "holderpro-private-output-test"] }
  ],
  "testPresets": [
    { "name": "macos-arm64", "configurePreset": "macos-arm64", "output": { "outputOnFailure": true } },
    { "name": "macos-x86_64", "configurePreset": "macos-x86_64", "output": { "outputOnFailure": true } },
    { "name": "linux-x86_64", "configurePreset": "linux-x86_64", "output": { "outputOnFailure": true } },
    { "name": "windows-x86_64", "configurePreset": "windows-x86_64", "output": { "outputOnFailure": true } }
  ]
}
